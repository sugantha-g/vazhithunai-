# Merged server reads this from the project root (dotenv default).
PORT=3001

# Map + routing + traffic provider used by the integrator's tracking/traffic
# services. Leave blank / FORCE_MOCK_MODE=true for an offline demo -- both
# services fall back to a realistic simulation with no API key needed.
MAP_PROVIDER=google            # google | mapbox
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=
FORCE_MOCK_MODE=true

# Set to true + drop a serviceAccountKey.json in the project root to use
# real Firestore instead of the in-memory mock DB.
USE_REAL_FIREBASE=false
